@inherits LayoutComponentBase
@inject IJSRuntime JS

<div class="app-root">
    <nav class="navbar">
        <a href="/" class="navbar-brand">
            <div class="logo-icon">L</div>
            <span>Liftoff Visualizer</span>
        </a>
        <div class="navbar-right">
            <button class="theme-toggle" @onclick="ToggleTheme" title="Toggle dark mode">
                @if (_isDark)
                {
                    <span>☀️</span>
                }
                else
                {
                    <span>🌙</span>
                }
            </button>
        </div>
    </nav>

    <main>
        @Body
    </main>
</div>

@code {
    private bool _isDark = false;

    private async Task ToggleTheme()
    {
        _isDark = !_isDark;
        var theme = _isDark ? "dark" : "light";
        await JS.InvokeVoidAsync("eval", $"document.documentElement.setAttribute('data-theme', '{theme}')");
        // Refresh chart colors
        await JS.InvokeVoidAsync("eval", "if(window.chartInterop) window.chartInterop.refreshAllCharts()");
    }
}
