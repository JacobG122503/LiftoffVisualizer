@inject IJSRuntime JS

<div class="exercise-card @(!_filteredData.Any() && _selectedDays != 0 ? "card--no-data" : "")" @onclick="OpenFullscreen" style="cursor:pointer">
    <div class="card-header">
        <div class="card-title-area">
            <div class="card-title" title="@ExerciseName">@ExerciseName</div>
            <div class="card-muscle-tag">@WorkoutDataService.GetMuscleGroup(ExerciseName)</div>
        </div>
        @{ var _trendCard = _displayTrend; }
        <div class="trend-indicator" title="@(_trendCard == "up" ? "Trending up" : _trendCard == "down" ? "Trending down" : "No change")">
            @if (_trendCard == "up")
            {
                <svg width="12" height="11" viewBox="0 0 12 11" xmlns="http://www.w3.org/2000/svg"><polygon points="6,0 12,11 0,11" fill="#4CAF50"/></svg>
            }
            else if (_trendCard == "down")
            {
                <svg width="12" height="11" viewBox="0 0 12 11" xmlns="http://www.w3.org/2000/svg"><polygon points="0,0 12,0 6,11" fill="#f44336"/></svg>
            }
            else
            {
                <svg width="14" height="6" viewBox="0 0 14 6" xmlns="http://www.w3.org/2000/svg"><line x1="1" y1="3" x2="13" y2="3" stroke="#9E9E9E" stroke-width="2" stroke-linecap="round"/></svg>
            }
        </div>
    </div>

    <div class="time-range-btns" @onclick:stopPropagation="true">
        @foreach (var range in _timeRanges)
        {
            <button class="time-btn @(range.Days == _selectedDays ? "active" : "")"
                    @onclick="() => SetTimeRange(range.Days)">
                @range.Label
            </button>
        }
    </div>

    <div class="metric-selector" @onclick:stopPropagation="true">
        <button class="metric-btn @(_selectedMetric == "est1rm" ? "active" : "")"
                @onclick='() => SetMetric("est1rm")'>Est. 1RM</button>
        <button class="metric-btn @(_selectedMetric == "weight" ? "active" : "")"
                @onclick='() => SetMetric("weight")'>Max Weight</button>
        <button class="metric-btn @(_selectedMetric == "volume" ? "active" : "")"
                @onclick='() => SetMetric("volume")'>Volume</button>
        <button class="metric-btn @(_selectedMetric == "reps" ? "active" : "")"
                @onclick='() => SetMetric("reps")'>Total Reps</button>
    </div>

    <div class="chart-container">
        <canvas id="@_canvasId"></canvas>
        @if (!_filteredData.Any() && _selectedDays != 0)
        {
            <div class="chart-no-data">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                </svg>
                <span>No sessions in this period</span>
            </div>
        }
    </div>

    @if (_filteredData.Any())
    {
        <div class="card-stats">
            <div class="card-stat">
                <div class="card-stat-value">@(_filteredData.Max(d => d.MaxWeight)) lbs</div>
                <div class="card-stat-label">Best Weight</div>
            </div>
            <div class="card-stat">
                @{
                    var est1rm = _filteredData.MaxBy(d => d.MaxEstimated1RM);
                }
                <div class="card-stat-value" style="padding-bottom:0.1em;">
                    @(est1rm?.MaxEstimated1RM.ToString("N0") ?? "-") lbs
                    @if (est1rm != null && est1rm.BestSet1RMWeight > 0 && est1rm.BestSet1RMReps > 0)
                    {
                        <span style="display:inline-block;margin-left:0.4em;color:#181A20;font-size:0.95em;font-weight:500;white-space:nowrap;vertical-align:middle;">(@est1rm.BestSet1RMWeight.ToString("N0") lbs × @est1rm.BestSet1RMReps reps)</span>
                    }
                </div>
                <div class="card-stat-label">Est. 1RM</div>
            </div>
            <div class="card-stat">
                <div class="card-stat-value">@(_filteredData.Max(d => d.TotalVolume).ToString("N0")) lbs</div>
                <div class="card-stat-label">Best Volume</div>
            </div>
            <div class="card-stat">
                <div class="card-stat-value">@_filteredData.Count</div>
                <div class="card-stat-label">Sessions</div>
            </div>
        </div>
    }
</div>

@if (_fullscreen)
{
    <div class="fs-overlay" @onclick="CloseFullscreen">
        <div class="fs-modal" @onclick:stopPropagation="true">
            <div class="fs-header">
                <div>
                    <div class="fs-title">@ExerciseName</div>
                    <div class="card-muscle-tag">@WorkoutDataService.GetMuscleGroup(ExerciseName)</div>
                </div>
                @{ var _trendFs = _displayTrend; }
                <div class="trend-indicator trend-indicator--lg" title="@(_trendFs == "up" ? "Trending up" : _trendFs == "down" ? "Trending down" : "No change")">
                    @if (_trendFs == "up")
                    {
                        <svg width="14" height="13" viewBox="0 0 12 11" xmlns="http://www.w3.org/2000/svg"><polygon points="6,0 12,11 0,11" fill="#4CAF50"/></svg>
                    }
                    else if (_trendFs == "down")
                    {
                        <svg width="14" height="13" viewBox="0 0 12 11" xmlns="http://www.w3.org/2000/svg"><polygon points="0,0 12,0 6,11" fill="#f44336"/></svg>
                    }
                    else
                    {
                        <svg width="16" height="7" viewBox="0 0 14 6" xmlns="http://www.w3.org/2000/svg"><line x1="1" y1="3" x2="13" y2="3" stroke="#9E9E9E" stroke-width="2" stroke-linecap="round"/></svg>
                    }
                </div>
                <button class="fs-close" @onclick="CloseFullscreen" title="Close">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                </button>
            </div>
            <div class="fs-controls">
                <div class="time-range-btns">
                    @foreach (var range in _timeRanges)
                    {
                        <button class="time-btn @(range.Days == _selectedDays ? "active" : "")"
                                @onclick="() => SetTimeRangeFullscreen(range.Days)">
                            @range.Label
                        </button>
                    }
                </div>
                <div class="metric-selector">
                    <button class="metric-btn @(_selectedMetric == "est1rm" ? "active" : "")"
                            @onclick='() => SetMetricFullscreen("est1rm")'>Est. 1RM</button>
                    <button class="metric-btn @(_selectedMetric == "weight" ? "active" : "")"
                            @onclick='() => SetMetricFullscreen("weight")'>Max Weight</button>
                    <button class="metric-btn @(_selectedMetric == "volume" ? "active" : "")"
                            @onclick='() => SetMetricFullscreen("volume")'>Volume</button>
                    <button class="metric-btn @(_selectedMetric == "reps" ? "active" : "")"
                            @onclick='() => SetMetricFullscreen("reps")'>Total Reps</button>
                </div>
            </div>
            <div class="fs-chart-container">
                <canvas id="@_fullscreenCanvasId"></canvas>
            </div>
            @if (_filteredData.Any())
            {
                <div class="card-stats fs-stats">
                    <div class="card-stat">
                        <div class="card-stat-value">@(_filteredData.Max(d => d.MaxWeight)) lbs</div>
                        <div class="card-stat-label">Best Weight</div>
                    </div>
                    <div class="card-stat">
                        @{
                            var est1rm = _filteredData.MaxBy(d => d.MaxEstimated1RM);
                        }
                        <div class="card-stat-value" style="padding-bottom:0.1em;">
                            @(est1rm?.MaxEstimated1RM.ToString("N0") ?? "-") lbs
                            @if (est1rm != null && est1rm.BestSet1RMWeight > 0 && est1rm.BestSet1RMReps > 0)
                            {
                                <span style="display:inline-block;margin-left:0.4em;color:#181A20;font-size:0.95em;font-weight:500;white-space:nowrap;vertical-align:middle;">(@est1rm.BestSet1RMWeight.ToString("N0") lbs × @est1rm.BestSet1RMReps reps)</span>
                            }
                        </div>
                        <div class="card-stat-label">Est. 1RM</div>
                    </div>
                    <div class="card-stat">
                        <div class="card-stat-value">@(_filteredData.Max(d => d.TotalVolume).ToString("N0")) lbs</div>
                        <div class="card-stat-label">Best Volume</div>
                    </div>
                    <div class="card-stat">
                        <div class="card-stat-value">@_filteredData.Count</div>
                        <div class="card-stat-label">Sessions</div>
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public string ExerciseName { get; set; } = "";
    [Parameter] public List<ExerciseSummary> AllData { get; set; } = new();
    [Parameter] public string? MetricOverride { get; set; }
    [Parameter] public int? DaysOverride { get; set; }
    [Parameter] public string TrendOverride { get; set; } = "";

    private string _displayTrend => string.IsNullOrEmpty(TrendOverride) ? GetTrendDirection() : TrendOverride;

    private string _canvasId = "";
    private string _fullscreenCanvasId = "";
    private int _selectedDays = 0; // 0 = all time
    private string _selectedMetric = "est1rm";
    private List<ExerciseSummary> _filteredData = new();
    private bool _chartRendered = false;
    private bool _fullscreen = false;

    private string _prevMetricOverride = "";
    private int? _prevDaysOverride = null;

    private string ActiveMetric => _selectedMetric;

    private static readonly (string Label, int Days)[] _timeRanges = new[]
    {
        ("15D", 15),
        ("30D", 30),
        ("90D", 90),
        ("6M", 180),
        ("1Y", 365),
        ("All", 0)
    };

    protected override void OnInitialized()
    {
        _canvasId = $"chart-{Guid.NewGuid():N}";
        _fullscreenCanvasId = $"chart-fs-{Guid.NewGuid():N}";
        FilterData();
    }

    protected override async Task OnParametersSetAsync()
    {
        // Sync local metric when global override changes
        if (MetricOverride != null && MetricOverride != _prevMetricOverride)
        {
            _selectedMetric = MetricOverride;
            _prevMetricOverride = MetricOverride;
        }
        // Sync local days when global override changes
        if (DaysOverride.HasValue && DaysOverride != _prevDaysOverride)
        {
            _selectedDays = DaysOverride.Value;
            _prevDaysOverride = DaysOverride;
        }
        FilterData();
        if (_chartRendered)
        {
            await RenderChart();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender || !_chartRendered)
        {
            await RenderChart();
            _chartRendered = true;
        }
    }

    private void FilterData()
    {
        if (_selectedDays == 0)
        {
            _filteredData = AllData;
        }
        else
        {
            var cutoff = DateTime.Now.AddDays(-_selectedDays);
            _filteredData = AllData.Where(d => d.Date >= cutoff).ToList();
        }
    }

    private async Task SetTimeRange(int days)
    {
        _selectedDays = days;
        FilterData();
        await RenderChart();
    }

    private async Task SetMetric(string metric)
    {
        _selectedMetric = metric;
        await RenderChart();
    }

    private async Task RenderChart()
    {
        if (!_filteredData.Any())
        {
            try { await JS.InvokeVoidAsync("chartInterop.destroyChart", _canvasId); } catch { }
            return;
        }
        await RenderChartOnCanvas(_canvasId);
    }

    private async Task OpenFullscreen()
    {
        _fullscreen = true;
        StateHasChanged();
        // Wait for the modal canvas to render
        await Task.Delay(50);
        await RenderChartOnCanvas(_fullscreenCanvasId);
    }

    private async Task CloseFullscreen()
    {
        _fullscreen = false;
        await JS.InvokeVoidAsync("chartInterop.destroyChart", _fullscreenCanvasId);
    }

    private async Task RenderChartOnCanvas(string canvasId)
    {
        if (!_filteredData.Any()) return;

        var labels = _filteredData.Select(d => d.Date.ToString("yyyy-MM-dd")).ToArray();
        var data = ActiveMetric switch
        {
            "volume"  => _filteredData.Select(d => d.TotalVolume).ToArray(),
            "reps"    => _filteredData.Select(d => (double)d.TotalReps).ToArray(),
            "est1rm"  => _filteredData.Select(d => Math.Round(d.MaxEstimated1RM, 1)).ToArray(),
            _         => _filteredData.Select(d => d.MaxWeight).ToArray()
        };
        var metricLabel = ActiveMetric switch
        {
            "volume"  => "Total Volume (lbs)",
            "reps"    => "Total Reps",
            "est1rm"  => "Est. 1RM (lbs)",
            _         => "Max Weight (lbs)"
        };

        // For est1rm, attach per-point tooltip subtitle (weight × reps of the best set)
        var tooltipExtras = ActiveMetric == "est1rm"
            ? _filteredData.Select(d => d.BestSet1RMWeight > 0
                ? $"{d.BestSet1RMWeight:N0} lbs \u00d7 {d.BestSet1RMReps} reps"
                : "").ToArray()
            : null;

        var datasets = new System.Collections.Generic.List<object>
        {
            new
            {
                label = metricLabel,
                data,
                borderColor = (string?)null,
                backgroundColor = (string?)null,
                pointBackgroundColor = (string?)null,
                pointBorderColor = "#fff",
                fill = true,
                tension = 0.3
            }
        };

        // Separate invisible dataset carries the orange tooltip subtitle for est1rm
        if (tooltipExtras != null)
        {
            datasets.Add(new
            {
                label = "",
                data,
                tooltipExtras = (object?)tooltipExtras,
                borderColor = "transparent",
                backgroundColor = "transparent",
                borderWidth = (object?)0,
                pointRadius = (object?)0,
                pointHoverRadius = (object?)0,
                fill = false,
                tension = 0.3
            });
        }

        if (data.Length >= 2)
        {
            var trend = ComputeTrendLine(data);
            datasets.Add(new
            {
                label = "Trend",
                data = trend,
                borderColor = "rgba(150,150,150,0.6)",
                backgroundColor = "transparent",
                pointBackgroundColor = "transparent",
                pointBorderColor = "transparent",
                fill = false,
                tension = 0.0,
                borderDash = new[] { 6, 4 },
                pointRadius = 0,
                pointHoverRadius = 0
            });
        }

        var config = new { type = "line", labels, datasets, beginAtZero = false };
        try
        {
            await JS.InvokeVoidAsync("chartInterop.createChart", canvasId, config);
        }
        catch { }
    }

    private static double[] ComputeTrendLine(double[] values)
    {
        int n = values.Length;
        double sumX = 0, sumY = 0, sumXY = 0, sumX2 = 0;
        for (int i = 0; i < n; i++)
        {
            sumX  += i;
            sumY  += values[i];
            sumXY += i * values[i];
            sumX2 += (double)i * i;
        }
        double denom = n * sumX2 - sumX * sumX;
        if (denom == 0) return values.Select(_ => Math.Round(sumY / n, 1)).ToArray();
        double slope     = (n * sumXY - sumX * sumY) / denom;
        double intercept = (sumY - slope * sumX) / n;
        return Enumerable.Range(0, n).Select(i => Math.Round(intercept + slope * i, 1)).ToArray();
    }

    private async Task SetTimeRangeFullscreen(int days)
    {
        _selectedDays = days;
        FilterData();
        await RenderChart();
        await RenderChartOnCanvas(_fullscreenCanvasId);
    }

    private async Task SetMetricFullscreen(string metric)
    {
        _selectedMetric = metric;
        await RenderChart();
        await RenderChartOnCanvas(_fullscreenCanvasId);
    }

    private string GetTrendDirection()
    {
        if (_filteredData.Count < 2) return "neutral";
        var data = ActiveMetric switch
        {
            "volume" => _filteredData.Select(d => d.TotalVolume).ToArray(),
            "reps"   => _filteredData.Select(d => (double)d.TotalReps).ToArray(),
            "est1rm" => _filteredData.Select(d => Math.Round(d.MaxEstimated1RM, 1)).ToArray(),
            _        => _filteredData.Select(d => d.MaxWeight).ToArray()
        };
        var trend = ComputeTrendLine(data);
        var change = trend[^1] - trend[0];
        var avg = data.Average();
        if (avg == 0) return "neutral";
        var relChange = change / avg;
        if (relChange > 0.01) return "up";
        if (relChange < -0.01) return "down";
        return "neutral";
    }
}
