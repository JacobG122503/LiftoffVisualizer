    private async Task ShareProgress()
    {
        var stats = new
        {
            totalWorkouts = _totalWorkouts,
            exerciseCount = _exerciseNames.Count,
            totalVolume = _totalVolume,
            totalSets = _totalSets,
            totalReps = _totalRepsAllTime,
            daysSinceStart = (DateTime.Now - _firstDate).Days,
            sinceDate = _firstDate.ToString("MMM yyyy"),
            longestStreak = _longestStreak,
            longestBreak = _longestBreak,
            favoriteExercise = _favoriteExercise,
            mostImprovedExercise = _mostImprovedExercise,
            mostImprovedGain = _mostImprovedGain,
            heaviestLift = _heaviestLift,
            heaviestExercise = _heaviestExercise,
            avgWorkoutsPerWeek = _avgWorkoutsPerWeek,
            busiestDay = _mostActiveWeekday
        };
        _previewImageUrl = await JS.InvokeAsync<string>("shareInterop.generatePreview", stats);
        _showSharePreview = true;
    }

