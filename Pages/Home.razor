@page "/"
@inject WorkoutDataService DataService
@inject IJSRuntime JS
@inject HttpClient Http

<PageTitle>Liftoff Visualizer</PageTitle>

<div class="page-container">
    @if (!DataService.HasData)
    {
        <div class="paste-landing">
            <h1 class="paste-title">Liftoff Visualizer</h1>
            <p class="paste-subtitle">Visualize your Liftoff workout history.</p>
            <p class="paste-hint">In Liftoff: <strong>Profile → Export Workouts</strong> → upload or paste the CSV below.</p>

            <label class="upload-zone @(_loading ? "upload-zone--parsing" : "")">
                <InputFile OnChange="OnFileSelected" accept=".csv" disabled="@_loading" />
                <div class="upload-zone-content">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                        <polyline points="17 8 12 3 7 8"/>
                        <line x1="12" y1="3" x2="12" y2="15"/>
                    </svg>
                    <span><strong>Upload CSV file</strong> or drag and drop</span>
                    <span class="upload-hint">liftoff_workout_data.csv</span>
                </div>
            </label>

            <div class="divider"><span>or paste CSV text</span></div>

            <textarea class="paste-input @(_loading ? "paste-input--parsing" : "")"
                      placeholder="Paste your CSV data here..."
                      @oninput="OnCsvInput"
                      disabled="@_loading"
                      rows="8"></textarea>

            @if (_loading)
            {
                <div class="paste-loading">
                    <div class="paste-spinner"></div>
                    <span>Analyzing your data...</span>
                </div>
            }
            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <div class="paste-error">@_errorMessage</div>
            }

            @if (!string.IsNullOrEmpty(_pwaBrowser))
            {
                @* PWA install hint ... *@
                <div class="pwa-install-hint">
                    <div class="pwa-install-hint-icon">📲</div>
                    <div class="pwa-install-hint-body">
                        <div class="pwa-install-hint-title">Add to Home Screen</div>
                        @if (_pwaBrowser == "ios-safari")
                        {
                            <div class="pwa-install-hint-text">Tap the <strong>Share ⬆️</strong> button in Safari, then <strong>"Add to Home Screen"</strong>.</div>
                        }
                        else if (_pwaBrowser == "ios-chrome" || _pwaBrowser == "ios-edge")
                        {
                            <div class="pwa-install-hint-text">Tap the <strong>Share ⬆️</strong> button, then <strong>"Add to Home Screen"</strong>.</div>
                        }
                        else if (_pwaBrowser == "ios-firefox")
                        {
                            <div class="pwa-install-hint-text">Open in <strong>Safari</strong>, then tap <strong>Share ⬆️ → Add to Home Screen</strong>.</div>
                        }
                        else if (_pwaBrowser == "android-chrome")
                        {
                            <div class="pwa-install-hint-text">Tap the <strong>⋮ menu</strong> in Chrome, then <strong>"Add to Home screen"</strong> or <strong>"Install app"</strong>.</div>
                        }
                        else if (_pwaBrowser == "android-samsung")
                        {
                            <div class="pwa-install-hint-text">Tap the <strong>☰ menu</strong>, then <strong>"Add page to" → "Home screen"</strong>.</div>
                        }
                        else if (_pwaBrowser == "android-firefox")
                        {
                            <div class="pwa-install-hint-text">Tap the <strong>⋮ menu</strong>, then <strong>"Install"</strong> or <strong>"Add to Home screen"</strong>.</div>
                        }
                        else
                        {
                            <div class="pwa-install-hint-text">Open the <strong>browser menu</strong> and tap <strong>"Add to Home Screen"</strong> or <strong>"Install app"</strong>.</div>
                        }
                    </div>
                </div>
            }

            @if (!string.IsNullOrEmpty(_lastUpdated))
            {
                <p class="build-date">Last Updated: @_lastUpdated</p>
            }
        </div>
    }
    else
    {
        <div class="page-header">
            <div>
                <h1 class="page-title">Your Lifting Journey</h1>
                <p class="page-subtitle">
                    @_totalWorkouts workouts tracked across @_exerciseNames.Count exercises since @_firstDate.ToString("MMM yyyy")
                </p>
            </div>
            <button class="share-btn" @onclick="ShareProgress" title="Share your progress">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
                    <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
                </svg>
                Share
            </button>
        </div>

        <!-- Summary Stats -->
        <div class="summary-grid">
            <div class="summary-card">
                <div class="summary-card-value">@_totalWorkouts</div>
                <div class="summary-card-label">Total Workouts</div>
            </div>
            <div class="summary-card">
                <div class="summary-card-value">@_exerciseNames.Count</div>
                <div class="summary-card-label">Exercises</div>
            </div>
            <div class="summary-card">
                <div class="summary-card-value">@_totalVolume.ToString("N0")</div>
                <div class="summary-card-label">Total Lbs Lifted</div>
            </div>
            <div class="summary-card">
                <div class="summary-card-value">@_totalSets.ToString("N0")</div>
                <div class="summary-card-label">Total Sets</div>
            </div>
            <div class="summary-card">
                <div class="summary-card-value">@((DateTime.Now - _firstDate).Days)</div>
                <div class="summary-card-label">Days Since Start</div>
            </div>
        </div>

        <!-- More Stats -->
        <details class="more-stats-section">
            <summary class="more-stats-toggle">More Stats</summary>
            <div class="more-stats-grid">
                <div class="more-stat-card">
                    <div class="more-stat-icon">🔥</div>
                    <div class="more-stat-value" style="@StatFontSize(_longestStreak.ToString())">@_longestStreak</div>
                    <div class="more-stat-label">Longest Streak (days)</div>
                </div>
                <div class="more-stat-card">
                    <div class="more-stat-icon">😴</div>
                    <div class="more-stat-value" style="@StatFontSize(_longestBreak.ToString())">@_longestBreak</div>
                    <div class="more-stat-label">Longest Break (days)</div>
                </div>
                <div class="more-stat-card">
                    <div class="more-stat-icon">⭐</div>
                    <div class="more-stat-value" style="@StatFontSize(_favoriteExercise)">@_favoriteExercise</div>
                    <div class="more-stat-label">Favorite Exercise</div>
                </div>
                <div class="more-stat-card">
                    <div class="more-stat-icon">📈</div>
                    <div class="more-stat-value" style="@StatFontSize(_mostImprovedExercise)">@_mostImprovedExercise</div>
                    <div class="more-stat-label">Most Improved (+@_mostImprovedGain.ToString("N0") lbs)</div>
                </div>
                <div class="more-stat-card">
                    <div class="more-stat-icon">📅</div>
                    <div class="more-stat-value" style="@StatFontSize(_mostActiveWeekday)">@_mostActiveWeekday</div>
                    <div class="more-stat-label">Day you train most often</div>
                </div>
                <div class="more-stat-card">
                    <div class="more-stat-icon">🗓️</div>
                    <div class="more-stat-value" style="@StatFontSize(_peakMonth)">@_peakMonth</div>
                    <div class="more-stat-label">Your most active month</div>
                </div>
                <div class="more-stat-card">
                    <div class="more-stat-icon">📊</div>
                    <div class="more-stat-value" style="@StatFontSize(_avgWorkoutsPerWeek.ToString())">@_avgWorkoutsPerWeek</div>
                    <div class="more-stat-label">Avg Workouts / Week</div>
                </div>
                <div class="more-stat-card">
                    <div class="more-stat-icon">💪</div>
                    <div class="more-stat-value" style="@StatFontSize(_totalRepsAllTime.ToString("N0"))">@_totalRepsAllTime.ToString("N0")</div>
                    <div class="more-stat-label">Total Reps All Time</div>
                </div>
                <div class="more-stat-card">
                    <div class="more-stat-icon">🏋️</div>
                    <div class="more-stat-value" style="@StatFontSize($"{_heaviestLift} lbs")">@_heaviestLift lbs</div>
                    <div class="more-stat-label">Heaviest Lift (@_heaviestExercise)</div>
                </div>
                <div class="more-stat-card">
                    <div class="more-stat-icon">⚡</div>
                    <div class="more-stat-value" style="@StatFontSize(_maxSetsInSession.ToString())">@_maxSetsInSession</div>
                    <div class="more-stat-label">Most Sets in One Day</div>
                    <div class="more-stat-date">set on @_maxSetsDate.ToString("MMM d, yyyy")</div>
                </div>
                <div class="more-stat-card">
                    <div class="more-stat-icon">🔄</div>
                    <div class="more-stat-value" style="@StatFontSize(_maxRepsInSession.ToString())">@_maxRepsInSession</div>
                    <div class="more-stat-label">Most Reps — @_maxRepsExercise</div>
                    <div class="more-stat-date">set on @_maxRepsDate.ToString("MMM d, yyyy")</div>
                </div>
                <div class="more-stat-card">
                    <div class="more-stat-icon">💥</div>
                    <div class="more-stat-value" style="@StatFontSize($"{_maxVolumeInSession:N0} lbs")">@_maxVolumeInSession.ToString("N0") lbs</div>
                    <div class="more-stat-label">Best Volume in One Day</div>
                    <div class="more-stat-date">set on @_maxVolumeDate.ToString("MMM d, yyyy")</div>
                </div>
                <div class="more-stat-card">
                    <div class="more-stat-icon">🧩</div>
                    <div class="more-stat-value" style="@StatFontSize(_maxExercisesInSession.ToString())">@_maxExercisesInSession</div>
                    <div class="more-stat-label">Most Exercises in One Day</div>
                    <div class="more-stat-date">set on @_maxExercisesDate.ToString("MMM d, yyyy")</div>
                </div>
                <div class="more-stat-card">
                    <div class="more-stat-icon">🌱</div>
                    <div class="more-stat-value" style="@StatFontSize(_firstExercise)">@_firstExercise</div>
                    <div class="more-stat-label">First Exercise Ever Logged</div>
                </div>
            </div>
            <!-- New Stats Row -->
            <div class="more-stats-grid">
                <div class="more-stat-card">
                    <div class="more-stat-icon">📅</div>
                    <div class="more-stat-value" style="@StatFontSize(_mostConsistentMonth)">@(!string.IsNullOrEmpty(_mostConsistentMonth) ? _mostConsistentMonth : "-")</div>
                    <div class="more-stat-label">Most Consistent Month</div>
                </div>
                <div class="more-stat-card">
                    <div class="more-stat-icon">⏱️</div>
                    <div class="more-stat-value">@(_avgWorkoutDuration > 0 ? _avgWorkoutDuration.ToString("N1") + " min" : "-")</div>
                    <div class="more-stat-label">Avg Workout Duration</div>
                </div>
                <div class="more-stat-card">
                    <div class="more-stat-icon">🌅</div>
                    <div class="more-stat-value" style="@StatFontSize(_earliestWorkoutTime.HasValue ? DateTime.Today.Add(_earliestWorkoutTime.Value).ToString("h:mm tt") : "-")">@(_earliestWorkoutTime.HasValue ? DateTime.Today.Add(_earliestWorkoutTime.Value).ToString("h:mm tt") : "-")</div>
                    <div class="more-stat-label">Earliest Workout Time</div>
                    @if (_earliestWorkoutDate.HasValue) { <div class="more-stat-date">on @_earliestWorkoutDate.Value.ToString("MMM d, yyyy")</div> }
                </div>
                <div class="more-stat-card">
                    <div class="more-stat-icon">🌙</div>
                    <div class="more-stat-value" style="@StatFontSize(_latestWorkoutTime.HasValue ? DateTime.Today.Add(_latestWorkoutTime.Value).ToString("h:mm tt") : "-")">@(_latestWorkoutTime.HasValue ? DateTime.Today.Add(_latestWorkoutTime.Value).ToString("h:mm tt") : "-")</div>
                    <div class="more-stat-label">Latest Workout Time</div>
                    @if (_latestWorkoutDate.HasValue) { <div class="more-stat-date">on @_latestWorkoutDate.Value.ToString("MMM d, yyyy")</div> }
                </div>
                <div class="more-stat-card">
                    <div class="more-stat-icon">🏷️</div>
                    <div class="more-stat-value" style="@StatFontSize(_mostFrequentWorkoutName)">@_mostFrequentWorkoutName</div>
                    <div class="more-stat-label">Most Frequent Workout Name</div>
                </div>
                <div class="more-stat-card">
                    <div class="more-stat-icon">🏋️‍♂️</div>
                    <div class="more-stat-value">@(_mostUsedWeight > 0 ? _mostUsedWeight.ToString("N0") : "-")</div>
                    <div class="more-stat-label">Most Used Weight</div>
                </div>
                <div class="more-stat-card">
                    <div class="more-stat-icon">🚴</div>
                    <div class="more-stat-value">@(_totalDistance > 0 ? _totalDistance.ToString("N1") : "-")</div>
                    <div class="more-stat-label">Total Distance</div>
                </div>
            </div>
        </details>

        <!-- Muscle Group Filter Pills -->
        <div class="muscle-pills">
            <button class="muscle-pill @(_selectedMuscle == "All" ? "active" : "")"
                    @onclick='() => FilterByMuscle("All")'>
                All <span class="pill-count">@_exerciseNames.Count</span>
            </button>
            @foreach (var mg in _muscleGroups.OrderBy(m => m.Key))
            {
                <button class="muscle-pill @(_selectedMuscle == mg.Key ? "active" : "")"
                        @onclick="() => FilterByMuscle(mg.Key)">
                    @mg.Key <span class="pill-count">@mg.Value</span>
                </button>
            }
        </div>

        <!-- Search -->
        <div class="filter-bar">
            <div class="search-wrapper">
                <span class="search-icon">🔍</span>
                <input type="text" placeholder="Search exercises..."
                       @bind="_searchQuery" @bind:event="oninput" />
            </div>
        </div>

        <!-- Global Controls Row: Range only -->
        <div class="global-controls-row">
            <div class="global-filters-inline">
                <span class="global-filter-label">Range</span>
                <div class="time-range-btns global-time-range">
                    @foreach (var range in _globalTimeRanges)
                    {
                        <button class="time-btn @(range.Days == _globalDays ? "active" : "")"
                                @onclick="() => SetGlobalDays(range.Days)">
                            @range.Label
                        </button>
                    }
                </div>
            </div>
        </div>

        <!-- Global Metric Selector -->
        <div class="metric-selector global-metric-selector">
            @foreach (var opt in _metricOptions)
            {
                <button class="metric-btn @(_globalMetric == opt.Key ? "active" : "")"
                        @onclick="() => SetGlobalMetric(opt.Key)">@opt.Label</button>
            }
        </div>

        <!-- Trend Summary Counts + Sort (directly above cards) -->
        <div class="trend-sort-row">
            <div class="trend-counts-row">
                <span class="trend-count trend-count--up" title="Trending up">
                    <svg width="10" height="9" viewBox="0 0 12 11" xmlns="http://www.w3.org/2000/svg"><polygon points="6,0 12,11 0,11" fill="#4CAF50"/></svg>
                    @(_filteredExercises.Where(HasDataInPeriod).Count(e => GetExerciseTrendDirection(e) == "up"))
                </span>
                <span class="trend-count trend-count--down" title="Trending down">
                    <svg width="10" height="9" viewBox="0 0 12 11" xmlns="http://www.w3.org/2000/svg"><polygon points="0,0 12,0 6,11" fill="#f44336"/></svg>
                    @(_filteredExercises.Where(HasDataInPeriod).Count(e => GetExerciseTrendDirection(e) == "down"))
                </span>
                <span class="trend-count trend-count--neutral" title="No change">
                    <svg width="12" height="5" viewBox="0 0 14 6" xmlns="http://www.w3.org/2000/svg"><line x1="1" y1="3" x2="13" y2="3" stroke="#9E9E9E" stroke-width="2" stroke-linecap="round"/></svg>
                    @(_filteredExercises.Where(HasDataInPeriod).Count(e => GetExerciseTrendDirection(e) == "neutral"))
                </span>
            </div>
            <div class="sort-select-wrap">
                <label class="sort-select-label" for="sort-select">Sort</label>
                <select id="sort-select" class="sort-select" @bind="_sortOrder">
                    <option value="recent">Most Recent</option>
                    <option value="trend_asc">Trending Up</option>
                    <option value="trend_desc">Trending Down</option>
                    <option value="alpha_asc">A → Z</option>
                    <option value="alpha_desc">Z → A</option>
                    <option value="sessions_desc">Most Sessions</option>
                    <option value="muscle">Muscle Group</option>
                </select>
            </div>
        </div>

        <!-- Exercise Cards Grid -->
        @if (_filteredExercises.Any())
        {
            <div class="exercise-grid">
                @foreach (var exercise in _filteredExercises)
                {
                    <LiftoffVisualizer.Components.ExerciseCard
                        @key="@exercise"
                        ExerciseName="@exercise"
                        AllData="@GetSummaryData(exercise)"
                        MetricOverride="@_globalMetric"
                        DaysOverride="@_globalDays"
                        TrendOverride="@GetExerciseTrendDirection(exercise)" />
                }
            </div>
        }
        else
        {
            <div class="no-data">
                <p>No exercises found matching your filters.</p>
            </div>
        }
    }
</div>

@if (_showSharePreview)
{
    <div class="share-preview-overlay" @onclick="ClosePreview">
        <div class="share-preview-modal" @onclick:stopPropagation="true">
            <div class="share-preview-header">
                <span>Share Your Progress</span>
                <button class="fs-close" @onclick="ClosePreview">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                </button>
            </div>
            <img src="@_previewImageUrl" class="share-preview-img" alt="Share preview" />
            <div class="share-preview-actions">
                <button class="share-preview-cancel" @onclick="ClosePreview">Cancel</button>
                <button class="share-btn" @onclick="ConfirmShare">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
                        <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
                    </svg>
                    Share / Download
                </button>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = false;
    private string _csvInput = "";
    private string _errorMessage = "";
    private CancellationTokenSource? _debounceCts;
    private string _lastUpdated = "";

    private List<string> _exerciseNames = new();
    private List<WorkoutRecord> _allRecords = new();
    private Dictionary<string, List<ExerciseSummary>> _summaryCache = new();
    private Dictionary<string, int> _muscleGroups = new();

    private string _selectedMuscle = "All";
    private string _searchQuery = "";
    private string _globalMetric = "est1rm";
    private int _globalDays = 0;

    private static readonly (string Label, int Days)[] _globalTimeRanges = new[]
    {
        ("15D", 15),
        ("30D", 30),
        ("90D", 90),
        ("6M", 180),
        ("1Y", 365),
        ("All", 0)
    };

    private static readonly (string Key, string Label)[] _metricOptions = new[]
    {
        ("est1rm", "Est. 1RM"),
        ("weight", "Max Weight"),
        ("volume", "Volume"),
        ("reps", "Total Reps")
    };

    private int _totalWorkouts;
    private double _totalVolume;
    private int _totalSets;
    private DateTime _firstDate;

    // Extra stats
    private int _longestStreak;
    private int _longestBreak;
    private string _favoriteExercise = "";
    private string _mostImprovedExercise = "";
    private double _mostImprovedGain;
    private string _mostActiveWeekday = "";
    private string _peakMonth = "";
    private double _avgWorkoutsPerWeek;
    private int _maxSetsInSession;
    private DateTime _maxSetsDate;
    private int _maxRepsInSession;
    private string _maxRepsExercise = "";
    private DateTime _maxRepsDate;
    private DateTime _maxVolumeDate;
    private double _heaviestLift;
    private string _heaviestExercise = "";
    private double _maxVolumeInSession;
    private int _maxExercisesInSession;
    private DateTime _maxExercisesDate;
    private string _firstExercise = "";
    private int _totalRepsAllTime;
    // New extra stats
    private string _mostConsistentMonth = "";
    private double _avgWorkoutDuration;
    private TimeSpan? _earliestWorkoutTime;
    private DateTime? _earliestWorkoutDate;
    private TimeSpan? _latestWorkoutTime;
    private DateTime? _latestWorkoutDate;
    private string _mostFrequentWorkoutName = "";
    private double _mostUsedWeight;
    private double _totalDistance;

    // Share preview
    private bool _showSharePreview = false;
    private string _previewImageUrl = "";

    // PWA install hint
    private string _pwaBrowser = "";
    private string _sortOrder = "recent";

    // Mirrors ExerciseCard.GetTrendDirection — uses the same metric, date range, and 1% threshold
    // so the sort order always matches the triangles shown on each card.
    private bool HasDataInPeriod(string name)
    {
        if (_globalDays == 0) return true;
        return _summaryCache.TryGetValue(name, out var allData)
            && allData.Any(d => d.Date >= DateTime.Now.AddDays(-_globalDays));
    }

    private string GetExerciseTrendDirection(string name)
    {
        if (!_summaryCache.TryGetValue(name, out var allData) || allData.Count < 2) return "neutral";
        var data = _globalDays == 0
            ? allData
            : allData.Where(d => d.Date >= DateTime.Now.AddDays(-_globalDays)).ToList();
        if (data.Count < 2) return "neutral";
        var values = _globalMetric switch
        {
            "volume" => data.Select(d => d.TotalVolume).ToArray(),
            "reps"   => data.Select(d => (double)d.TotalReps).ToArray(),
            "est1rm" => data.Select(d => Math.Round(d.MaxEstimated1RM, 1)).ToArray(),
            _        => data.Select(d => d.MaxWeight).ToArray()
        };
        int n = values.Length;
        double sumX = 0, sumY = 0, sumXY = 0, sumX2 = 0;
        for (int i = 0; i < n; i++) { sumX += i; sumY += values[i]; sumXY += i * values[i]; sumX2 += (double)i * i; }
        double denom = n * sumX2 - sumX * sumX;
        if (denom == 0) return "neutral";
        double slope = (n * sumXY - sumX * sumY) / denom;
        double intercept = (sumY - slope * sumX) / n;
        var trend = Enumerable.Range(0, n).Select(i => Math.Round(intercept + slope * i, 1)).ToArray();
        double change = trend[^1] - trend[0];
        double avg = values.Average();
        if (avg == 0) return "neutral";
        double relChange = change / avg;
        if (relChange > 0.01) return "up";
        if (relChange < -0.01) return "down";
        return "neutral";
    }

    private List<string> _filteredExercises => _exerciseNames
        .Where(e =>
            (_selectedMuscle == "All" || WorkoutDataService.GetMuscleGroup(e) == _selectedMuscle)
            && (string.IsNullOrWhiteSpace(_searchQuery) || e.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase))
        )
        .OrderBy(e => HasDataInPeriod(e) ? 0 : 1)
        .ThenBy(e => _sortOrder switch
        {
            "alpha_asc"     => (object)e,
            "alpha_desc"    => (object)string.Concat(e.Select(c => (char)(char.MaxValue - c))),
            "muscle"        => (object)WorkoutDataService.GetMuscleGroup(e),
            "sessions_desc" => (object)(_summaryCache.TryGetValue(e, out var sd) ? int.MaxValue - sd.Count : int.MaxValue),
            // bucket by the same direction as the triangle: down=0, neutral=1, up=2
            "trend_desc"    => (object)(GetExerciseTrendDirection(e) switch { "down" => 0, "neutral" => 1, _ => 2 }),
            // bucket by the same direction as the triangle: up=0, neutral=1, down=2
            "trend_asc"     => (object)(GetExerciseTrendDirection(e) switch { "up" => 0, "neutral" => 1, _ => 2 }),
            _               => (object)(_summaryCache.TryGetValue(e, out var d) && d.Any() ? DateTime.MaxValue - d.Max(s => s.Date) : TimeSpan.MaxValue)
        })
        .ToList();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var isMobile = await JS.InvokeAsync<bool>("pwaHelper.isMobile");
            var isStandalone = await JS.InvokeAsync<bool>("pwaHelper.isStandalone");
            if (isMobile && !isStandalone)
            {
                _pwaBrowser = await JS.InvokeAsync<string>("pwaHelper.getBrowser");
                StateHasChanged();
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var info = await Http.GetFromJsonAsync<BuildInfo>("data/buildinfo.json");
            if (info?.buildDate is not null)
            {
                var utc = DateTime.Parse(info.buildDate, null, System.Globalization.DateTimeStyles.RoundtripKind);
                _lastUpdated = utc.ToLocalTime().ToString("MMM d, yyyy h:mm tt");
            }
        }
        catch { }
    }

    private record BuildInfo(string? buildDate = null);

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        _errorMessage = "";
        _loading = true;
        StateHasChanged();

        try
        {
            using var stream = e.File.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            using var reader = new System.IO.StreamReader(stream);
            _csvInput = await reader.ReadToEndAsync();
        }
        catch
        {
            _errorMessage = "Could not read the file. Please try again.";
            _loading = false;
            return;
        }

        await LoadData();
    }

    private async Task OnCsvInput(ChangeEventArgs e)
    {
        _csvInput = e.Value?.ToString() ?? "";
        _errorMessage = "";

        if (string.IsNullOrWhiteSpace(_csvInput))
        {
            _loading = false;
            _debounceCts?.Cancel();
            return;
        }

        _loading = true;
        StateHasChanged();

        _debounceCts?.Cancel();
        _debounceCts = new CancellationTokenSource();
        var token = _debounceCts.Token;

        try
        {
            await Task.Delay(600, token);
        }
        catch (TaskCanceledException)
        {
            return;
        }

        await LoadData();
    }

    private async Task LoadData()
    {
        if (string.IsNullOrWhiteSpace(_csvInput)) return;
        _errorMessage = "";
        _loading = true;

        try
        {
            DataService.LoadFromText(_csvInput);

            _allRecords = await DataService.GetRecordsAsync();

            if (_allRecords.Count == 0)
            {
                _errorMessage = "No valid workout records found. Make sure you pasted the full Liftoff CSV export.";
                DataService.Reset();
                _loading = false;
                return;
            }

            _exerciseNames = await DataService.GetExerciseNamesAsync();

            foreach (var name in _exerciseNames)
                _summaryCache[name] = await DataService.GetExerciseSummariesAsync(name);

            _muscleGroups = _exerciseNames
                .GroupBy(WorkoutDataService.GetMuscleGroup)
                .ToDictionary(g => g.Key, g => g.Count());

            _totalWorkouts = _allRecords.Select(r => r.Date.Date).Distinct().Count();
            _totalVolume = _allRecords.Sum(r => r.Weight * r.Reps);
            _totalSets = _allRecords.Count;
            _firstDate = _allRecords.Min(r => r.Date);

            // Compute extra stats
            var workoutDays = _allRecords.Select(r => r.Date.Date).Distinct().OrderBy(d => d).ToList();

            // Streak (up to 2-day gap allowed) & longest break
            int streak = 1, maxStreak = 1, maxBreak = 0;
            for (int i = 1; i < workoutDays.Count; i++)
            {
                var gap = (workoutDays[i] - workoutDays[i - 1]).Days;
                if (gap <= 3) { streak++; maxStreak = Math.Max(maxStreak, streak); }
                else { streak = 1; }
                if (gap > 1) maxBreak = Math.Max(maxBreak, gap - 1);
            }
            _longestStreak = maxStreak;
            _longestBreak = maxBreak;

            // Favorite exercise (most sessions)
            _favoriteExercise = _summaryCache
                .OrderByDescending(kv => kv.Value.Count)
                .Select(kv => kv.Key).FirstOrDefault() ?? "";

            // Most improved (biggest absolute weight gain, exercises with weight > 0)
            var improved = _summaryCache
                .Where(kv => kv.Value.Any(s => s.MaxWeight > 0))
                .Select(kv => new {
                    Name = kv.Key,
                    Gain = kv.Value.Max(s => s.MaxWeight) - kv.Value.First(s => s.MaxWeight > 0).MaxWeight
                })
                .OrderByDescending(x => x.Gain).FirstOrDefault();
            _mostImprovedExercise = improved?.Name ?? "";
            _mostImprovedGain = improved?.Gain ?? 0;

            // Day of week you train most often
            _mostActiveWeekday = workoutDays
                .GroupBy(d => d.DayOfWeek)
                .OrderByDescending(g => g.Count())
                .Select(g => g.Key.ToString() + "s").FirstOrDefault() ?? "";

            // Month with most workout days
            _peakMonth = workoutDays
                .GroupBy(d => new { d.Year, d.Month })
                .OrderByDescending(g => g.Count())
                .Select(g => new DateTime(g.Key.Year, g.Key.Month, 1).ToString("MMM yyyy"))
                .FirstOrDefault() ?? "";

            // Avg workouts per week
            var totalWeeks = Math.Max(1, (DateTime.Now - _firstDate).TotalDays / 7.0);
            _avgWorkoutsPerWeek = Math.Round(_totalWorkouts / totalWeeks, 1);

            // Max sets in a single session
            var maxSetsGroup = _allRecords
                .GroupBy(r => r.Date.Date)
                .OrderByDescending(g => g.Count()).First();
            _maxSetsInSession = maxSetsGroup.Count();
            _maxSetsDate = maxSetsGroup.Key;

            // Max reps for one exercise on one day
            var maxRepsGroup = _allRecords
                .GroupBy(r => new { r.Date.Date, r.ExerciseName })
                .OrderByDescending(g => g.Sum(r => r.Reps)).First();
            _maxRepsInSession = maxRepsGroup.Sum(r => r.Reps);
            _maxRepsExercise = maxRepsGroup.Key.ExerciseName;
            _maxRepsDate = maxRepsGroup.Key.Date;

            // Heaviest single lift
            var heaviest = _allRecords.Where(r => r.Weight > 0)
                .OrderByDescending(r => r.Weight).FirstOrDefault();
            _heaviestLift = heaviest?.Weight ?? 0;
            _heaviestExercise = heaviest?.ExerciseName ?? "";

            // Max volume in a single session
            var maxVolGroup = _allRecords
                .GroupBy(r => r.Date.Date)
                .OrderByDescending(g => g.Sum(r => r.Weight * r.Reps)).First();
            _maxVolumeInSession = maxVolGroup.Sum(r => r.Weight * r.Reps);
            _maxVolumeDate = maxVolGroup.Key;

            // Max exercises in a single session
            var maxExercisesGroup = _allRecords
                .GroupBy(r => r.Date.Date)
                .OrderByDescending(g => g.Select(r => r.ExerciseName).Distinct().Count())
                .FirstOrDefault();
            _maxExercisesInSession = maxExercisesGroup != null ? maxExercisesGroup.Select(r => r.ExerciseName).Distinct().Count() : 0;
            _maxExercisesDate = maxExercisesGroup != null ? maxExercisesGroup.Key : DateTime.MinValue;

            // First exercise ever logged
            _firstExercise = _allRecords
                .OrderBy(r => r.Date).Select(r => r.ExerciseName).FirstOrDefault() ?? "";

            // Total reps all time
            _totalRepsAllTime = _allRecords.Sum(r => r.Reps);

            // --- New extra stats ---
            // 1. Most Consistent Month (highest % of days trained in month)
            var monthGroups = workoutDays.GroupBy(d => new { d.Year, d.Month })
                .Select(g => new {
                    Year = g.Key.Year,
                    Month = g.Key.Month,
                    DaysTrained = g.Count(),
                    DaysInMonth = DateTime.DaysInMonth(g.Key.Year, g.Key.Month)
                })
                .Select(x => new {
                    x.Year,
                    x.Month,
                    Consistency = (double)x.DaysTrained / x.DaysInMonth
                })
                .OrderByDescending(x => x.Consistency)
                .FirstOrDefault();
            _mostConsistentMonth = monthGroups != null ? new DateTime(monthGroups.Year, monthGroups.Month, 1).ToString("MMM yyyy") : "";

            // 2. Average Workout Duration (if Duration > 0)
            // Parse Duration as double (minutes), skip invalid
            var durations = _allRecords
                .Select(r => new { r.Date, Minutes = LiftoffVisualizer.Pages.DurationParser.ParseToMinutes(r.Duration) })
                .Where(x => x.Minutes > 0)
                .GroupBy(x => x.Date.Date)
                .Select(g => g.Max(x => x.Minutes));
            _avgWorkoutDuration = durations.Any() ? durations.Average() : 0;

            // 3. Earliest Workout Time
            var earliestRecord = _allRecords.OrderBy(r => r.Date.TimeOfDay).FirstOrDefault();
            _earliestWorkoutTime = earliestRecord != null ? earliestRecord.Date.TimeOfDay : (TimeSpan?)null;
            _earliestWorkoutDate = earliestRecord?.Date.Date;

            // 4. Latest Workout Time
            var latestRecord = _allRecords.OrderByDescending(r => r.Date.TimeOfDay).FirstOrDefault();
            _latestWorkoutTime = latestRecord != null ? latestRecord.Date.TimeOfDay : (TimeSpan?)null;
            _latestWorkoutDate = latestRecord?.Date.Date;

            // 5. Most Frequent Workout Name
            // Most Frequent Workout Name (handle empty)
            var mostFreqGroup = _allRecords
                .Where(r => !string.IsNullOrWhiteSpace(r.WorkoutName))
                .GroupBy(r => r.WorkoutName)
                .OrderByDescending(g => g.Count())
                .FirstOrDefault();
            _mostFrequentWorkoutName = mostFreqGroup != null ? mostFreqGroup.Key : "-";

            // 6. Most Used Weight
            var weightGroups = _allRecords.Where(r => r.Weight > 0)
                .GroupBy(r => r.Weight)
                .OrderByDescending(g => g.Count())
                .FirstOrDefault();
            _mostUsedWeight = weightGroups?.Key ?? 0;

            // 7. Total Distance (if Distance > 0)
            _totalDistance = _allRecords.Where(r => r.Distance > 0).Sum(r => r.Distance);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to parse CSV: {ex.Message}";
            DataService.Reset();
        }

        _loading = false;
    }

    private List<ExerciseSummary> GetSummaryData(string exerciseName)
    {
        return _summaryCache.TryGetValue(exerciseName, out var data) ? data : new();
    }

